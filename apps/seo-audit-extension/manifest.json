{
    "manifest_version":  3,
    "name":  "AutoPub SEO Page Audit Analyzer",
    "version":  "0.1.0",
    "description":  "Scan current page SEO basics, score issues, and prepare AI repair suggestions.",
    "permissions":  [
                        "activeTab",
                        "scripting",
                        "storage"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "action":  {
                   "default_popup":  "popup.html",
                   "default_icon":  {
                                       "16":  "icon16.png",
                                       "48":  "icon48.png",
                                       "128":  "icon128.png"
                                   }
               },
    "background":  {
                       "service_worker":  "background.js"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle"
                            }
                        ],
    "icons":  {
                  "16":  "icon16.png",
                  "48":  "icon48.png",
                  "128":  "icon128.png"
              }
}
